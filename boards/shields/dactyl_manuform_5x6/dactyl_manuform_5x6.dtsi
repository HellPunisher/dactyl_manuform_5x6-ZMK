#include <dt-bindings/zmk/matrix_transform.h>

/ {
    chosen {
        zmk,battery = &vbatt;
        zmk,kscan = &kscan0;
        zmk,matrix_transform = &default_transform;
    };
    vbatt: vbatt {
        compatible = "zmk,battery-nrf-vddh";
    };
    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <12>;
        rows = <6>;
// | SW1  | SW2  | SW3  | SW4  | SW5  | SW6  |                 | SW6  | SW5  | SW4  | SW3  | SW2  | SW1 |
// | SW7  | SW8  | SW9  | SW10 | SW11 | SW12 |                 | SW12 | SW11 | SW10 | SW9  | SW8  | SW7 |
// | SW13 | SW14 | SW15 | SW16 | SW17 | SW18 |                 | SW18 | SW17 | SW16 | SW15 | SW14 | SW13 |
// | SW19 | SW20 | SW21 | SW22 | SW23 | SW24 |                 | SW24 | SW23 | SW22 | SW21 | SW20 | SW19 |
//               | SW25 |      | SW27 | SW28 |                 | SW28 | SW27 |      | SW25 |
// 
//                             | SW29 | SW30 |                 | SW30 | SW29 |
//                             | SW31 | SW32 |                 | SW32 | SW31 |
map = <
RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)                     RC(0,11) RC(0,10) RC(0,9) RC(0,8) RC(0,7) RC(0,6)
RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)                     RC(1,11) RC(1,10) RC(1,9) RC(1,8) RC(1,7) RC(1,6)
RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)                     RC(2,11) RC(2,10) RC(2,9) RC(2,8) RC(2,7) RC(2,6)
RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5)                     RC(3,11) RC(3,10) RC(3,9) RC(3,8) RC(3,7) RC(3,6)
                RC(4,2)         RC(4,4) RC(4,5)                     RC(4,11) RC(4,10)          RC(4,8)

                                RC(5,4) RC(5,5)                     RC(5,11) RC(5,10)
                                RC(5,4) RC(5,5)                     RC(5,9)  RC(5,8)
        >;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        label = "KSCAN";
        diode-direction = "col2row";

        row-gpios
            = <&pro_micro 2 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> // R0 -> D2 (0.15)
            , <&pro_micro 3 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> // R1 -> D3 (0.17)
            , <&pro_micro 4 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> // R2 -> D4 (0.20)
            , <&pro_micro 5 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> // R3 -> D5 (0.13)
            , <&pro_micro 6 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> // R4 -> D6 (0.24)
            , <&pro_micro 9 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> // R5 -> D9 (1.06)
            ;

        col-gpios
            = <&pro_micro 10 GPIO_ACTIVE_HIGH> // C0 -> D10 (1.11)
            , <&pro_micro 11 GPIO_ACTIVE_HIGH> // C1 -> D11 (0.28)
            , <&pro_micro 12 GPIO_ACTIVE_HIGH> // C2 -> D12 (0.03)
            , <&pro_micro 13 GPIO_ACTIVE_HIGH> // C3 -> D13 (1.13)
            , <&pro_micro 14 GPIO_ACTIVE_HIGH> // C4 -> D14 (0.02)
            , <&pro_micro 15 GPIO_ACTIVE_HIGH> // C5 -> D15 (0.29)
            ;
    };
};

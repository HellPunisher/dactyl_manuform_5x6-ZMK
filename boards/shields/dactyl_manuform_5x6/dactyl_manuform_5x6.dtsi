#include <dt-bindings/zmk/matrix_transform.h>
#include <physical_layouts.dtsi>

/ {
    chosen {
        zmk,battery = &vbatt;
        zmk,kscan = &kscan0;
        zmk,physical-layout = &default_layout;
    };

    vbatt: vbatt {
        compatible = "zmk,battery-nrf-vddh";
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <12>;
        rows = <6>;
// | SW1  | SW2  | SW3  | SW4  | SW5  | SW6  |                 | SW6  | SW5  | SW4  | SW3  | SW2  | SW1 |
// | SW7  | SW8  | SW9  | SW10 | SW11 | SW12 |                 | SW12 | SW11 | SW10 | SW9  | SW8  | SW7 |
// | SW13 | SW14 | SW15 | SW16 | SW17 | SW18 |                 | SW18 | SW17 | SW16 | SW15 | SW14 | SW13 |
// | SW19 | SW20 | SW21 | SW22 | SW23 | SW24 |                 | SW24 | SW23 | SW22 | SW21 | SW20 | SW19 |
//                | SW25 |      | SW27 | SW28 |                 | SW28 | SW27 |      | SW25 |
// 
//                               | SW29 | SW30 |                 | SW30 | SW29 |
//                               | SW31 | SW32 |                 | SW32 | SW31 |
        map = <
RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)                     RC(0,11) RC(0,10) RC(0,9) RC(0,8) RC(0,7) RC(0,6)
RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)                     RC(1,11) RC(1,10) RC(1,9) RC(1,8) RC(1,7) RC(1,6)
RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)                     RC(2,11) RC(2,10) RC(2,9) RC(2,8) RC(2,7) RC(2,6)
RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5)                     RC(3,11) RC(3,10) RC(3,9) RC(3,8) RC(3,7) RC(3,6)
                RC(4,2)         RC(4,4) RC(4,5)                     RC(4,11) RC(4,10)          RC(4,8)

                                RC(5,4) RC(5,5)                     RC(5,11) RC(5,10)
                                RC(5,2) RC(5,3)                     RC(5,9)  RC(5,8)
        >;
    };

    layouts {
        compatible = "zmk,physical-layouts";
        
        default_layout: default_layout {
            compatible = "zmk,physical-layout";
            display-name = "Dactyl Manuform 5x6";
            transform = <&default_transform>;
            kscan = <&kscan0>;
            keys
                /* Ряд 0 (Y=0) */
                = <&key_physical_attrs 100 100    0   0 0 0 0> , <&key_physical_attrs 100 100  100   0 0 0 0> , <&key_physical_attrs 100 100  200   0 0 0 0> , <&key_physical_attrs 100 100  300   0 0 0 0> , <&key_physical_attrs 100 100  400   0 0 0 0> , <&key_physical_attrs 100 100  500   0 0 0 0> 
                , <&key_physical_attrs 100 100  800   0 0 0 0> , <&key_physical_attrs 100 100  900   0 0 0 0> , <&key_physical_attrs 100 100 1000   0 0 0 0> , <&key_physical_attrs 100 100 1100   0 0 0 0> , <&key_physical_attrs 100 100 1200   0 0 0 0> , <&key_physical_attrs 100 100 1300   0 0 0 0>
                
                /* Ряд 1 (Y=100) */
                , <&key_physical_attrs 100 100    0 100 0 0 0> , <&key_physical_attrs 100 100  100 100 0 0 0> , <&key_physical_attrs 100 100  200 100 0 0 0> , <&key_physical_attrs 100 100  300 100 0 0 0> , <&key_physical_attrs 100 100  400 100 0 0 0> , <&key_physical_attrs 100 100  500 100 0 0 0> 
                , <&key_physical_attrs 100 100  800 100 0 0 0> , <&key_physical_attrs 100 100  900 100 0 0 0> , <&key_physical_attrs 100 100 1000 100 0 0 0> , <&key_physical_attrs 100 100 1100 100 0 0 0> , <&key_physical_attrs 100 100 1200 100 0 0 0> , <&key_physical_attrs 100 100 1300 100 0 0 0>
                
                /* Ряд 2 (Y=200) */
                , <&key_physical_attrs 100 100    0 200 0 0 0> , <&key_physical_attrs 100 100  100 200 0 0 0> , <&key_physical_attrs 100 100  200 200 0 0 0> , <&key_physical_attrs 100 100  300 200 0 0 0> , <&key_physical_attrs 100 100  400 200 0 0 0> , <&key_physical_attrs 100 100  500 200 0 0 0> 
                , <&key_physical_attrs 100 100  800 200 0 0 0> , <&key_physical_attrs 100 100  900 200 0 0 0> , <&key_physical_attrs 100 100 1000 200 0 0 0> , <&key_physical_attrs 100 100 1100 200 0 0 0> , <&key_physical_attrs 100 100 1200 200 0 0 0> , <&key_physical_attrs 100 100 1300 200 0 0 0>
                
                /* Ряд 3 (Y=300) */
                , <&key_physical_attrs 100 100    0 300 0 0 0> , <&key_physical_attrs 100 100  100 300 0 0 0> , <&key_physical_attrs 100 100  200 300 0 0 0> , <&key_physical_attrs 100 100  300 300 0 0 0> , <&key_physical_attrs 100 100  400 300 0 0 0> , <&key_physical_attrs 100 100  500 300 0 0 0> 
                , <&key_physical_attrs 100 100  800 300 0 0 0> , <&key_physical_attrs 100 100  900 300 0 0 0> , <&key_physical_attrs 100 100 1000 300 0 0 0> , <&key_physical_attrs 100 100 1100 300 0 0 0> , <&key_physical_attrs 100 100 1200 300 0 0 0> , <&key_physical_attrs 100 100 1300 300 0 0 0>
                
                /* Ряд 4 матрицы (Y=400) */
                , <&key_physical_attrs 100 100  200 400 0 0 0> , <&key_physical_attrs 100 100  400 400 0 0 0> , <&key_physical_attrs 100 100  500 400 0 0 0> 
                , <&key_physical_attrs 100 100  800 400 0 0 0> , <&key_physical_attrs 100 100  900 400 0 0 0> , <&key_physical_attrs 100 100 1100 400 0 0 0>
                
                /* Ряд 5 матрицы, линия 1 (Y=500) */
                , <&key_physical_attrs 100 100  400 500 0 0 0> , <&key_physical_attrs 100 100  500 500 0 0 0> 
                , <&key_physical_attrs 100 100  800 500 0 0 0> , <&key_physical_attrs 100 100  900 500 0 0 0>
                
                /* Ряд 5 матрицы, линия 2 (Y=600) */
                , <&key_physical_attrs 100 100  400 600 0 0 0> , <&key_physical_attrs 100 100  500 600 0 0 0> 
                , <&key_physical_attrs 100 100  800 600 0 0 0> , <&key_physical_attrs 100 100  900 600 0 0 0>
                ;
        };
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        label = "KSCAN";
        diode-direction = "col2row";

        row-gpios
            = <&gpio0 15 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> // R0 -> P0.15 (D2)
            , <&gpio0 17 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> // R1 -> P0.17 (D3)
            , <&gpio0 20 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> // R2 -> P0.20 (D4)
            , <&gpio0 13 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> // R3 -> P0.13 (D5)
            , <&gpio0 24 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> // R4 -> P0.24 (D6)
            , <&gpio1  6 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> // R5 -> P1.06 (D9)
            ;

        col-gpios
            = <&gpio0 29 GPIO_ACTIVE_HIGH> // C0 -> P0.29 (D15)
            , <&gpio0  2 GPIO_ACTIVE_HIGH> // C1 -> P0.02 (D14)
            , <&gpio1 13 GPIO_ACTIVE_HIGH> // C2 -> P1.13 (D13)
            , <&gpio0  3 GPIO_ACTIVE_HIGH> // C3 -> P0.03 (D12)
            , <&gpio0 28 GPIO_ACTIVE_HIGH> // C4 -> P0.28 (D11)
            , <&gpio1 11 GPIO_ACTIVE_HIGH> // C5 -> P1.11 (D10)
            ;
    };
};
